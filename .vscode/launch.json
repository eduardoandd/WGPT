{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug wGPT (Client + Server)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "cwd": "${workspaceFolder}",
            "autoAttachChildProcesses": true,
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}